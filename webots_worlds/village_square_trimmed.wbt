  orientation -0.34 -0.18 0.92 4.2
  position 19 13 12
  follow "TurtleBot3Burger:lidar3d"
}
TexturedBackground {
  texture "noon_cloudy_countryside"
}
TexturedBackgroundLight {
}

Floor {
  translation 0 0 0
  name "trimmed_square_ground"
  size 34 34
  tileSize 4 4
}

# Closed outer edges. These are intentionally lidar-visible so SLAM sees a
# bounded trimmed section instead of an open, featureless outdoor plane.
Solid {
  translation 0 16 0.5
  name "road_closed_north"
  children [
    Shape { appearance PBRAppearance { baseColor 0.8 0.08 0.04 roughness 0.65 metalness 0 } geometry Box { size 32 0.3 1.0 } }
  ]
  boundingObject Box { size 32 0.3 1.0 }
  locked TRUE
}

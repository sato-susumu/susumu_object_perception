{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/auto_improve_hook.py\" arm",
            "timeout": 10,
            "statusMessage": "Checking continuous improvement trigger"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/auto_improve_hook.py\" stop",
            "timeout": 10,
            "statusMessage": "Checking continuous improvement loop"
          }
        ]
      }
    ]
  }
}

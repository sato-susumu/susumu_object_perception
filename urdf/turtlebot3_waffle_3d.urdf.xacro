<?xml version="1.0" ?>
<!--
  TurtleBot3 Waffle + 3D LiDAR (Velodyne VLP-16 style) description, used by
  robot_state_publisher to provide TF (including base_link -> velodyne_link).

  The Gazebo sensor itself lives in the SDF model
  (susumu_object_perception/models/turtlebot3_waffle_3d/model.sdf); this file only adds the
  matching velodyne_link frame so TF and the SDF agree.
-->
<robot name="turtlebot3_waffle_3d" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Standard waffle body (links, wheels, 2D scan, camera, imu frames) -->
  <xacro:include filename="$(find turtlebot3_description)/urdf/turtlebot3_waffle.urdf"/>

  <!-- 3D LiDAR frame, mounted on top of base_link (matches model.sdf pose) -->
  <joint name="velodyne_joint" type="fixed">
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="velodyne_link"/>
  </joint>

  <link name="velodyne_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0516" length="0.0717"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0516" length="0.0717"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.83"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- 360-degree RGB rig frame (matches model.sdf). The six face frames are
       published for calibration bookkeeping; omni_image_node.py stitches their
       images into one equirectangular image. -->
  <joint name="omni_camera_joint" type="fixed">
    <origin xyz="0 0 0.75" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="omni_camera_link"/>
  </joint>

  <link name="omni_camera_link">
    <visual>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
      <material name="black"/>
    </visual>
    <inertial>
      <mass value="0.12"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0002" ixy="0" ixz="0"
               iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="omni_front_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="omni_camera_link"/>
    <child link="omni_front_frame"/>
  </joint>
  <link name="omni_front_frame"/>

  <joint name="omni_left_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 1.57079632679"/>
    <parent link="omni_camera_link"/>
    <child link="omni_left_frame"/>
  </joint>
  <link name="omni_left_frame"/>

  <joint name="omni_back_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 3.14159265359"/>
    <parent link="omni_camera_link"/>
    <child link="omni_back_frame"/>
  </joint>
  <link name="omni_back_frame"/>

  <joint name="omni_right_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 -1.57079632679"/>
    <parent link="omni_camera_link"/>
    <child link="omni_right_frame"/>
  </joint>
  <link name="omni_right_frame"/>

  <joint name="omni_up_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 -1.57079632679 0"/>
    <parent link="omni_camera_link"/>
    <child link="omni_up_frame"/>
  </joint>
  <link name="omni_up_frame"/>

  <joint name="omni_down_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 1.57079632679 0"/>
    <parent link="omni_camera_link"/>
    <child link="omni_down_frame"/>
  </joint>
  <link name="omni_down_frame"/>

</robot>

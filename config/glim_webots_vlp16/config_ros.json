{
  "glim_ros": {
    "enable_local_mapping": true,
    "enable_global_mapping": true,
    "keep_raw_points": false,
    "imu_time_offset": 0.0,
    "points_time_offset": 0.0,
    "acc_scale": 1.0,
    "imu_frame_id": "glim_imu",
    "lidar_frame_id": "glim_lidar",
    "base_frame_id": "glim_lidar",
    "odom_frame_id": "glim_odom",
    "map_frame_id": "glim_map",
    "publish_imu2lidar": true,
    "tf_time_offset": 1e-6,
    "extension_modules": [
      "libmemory_monitor.so",
      "librviz_viewer.so"
    ],
    "imu_topic": "/imu",
    "points_topic": "/lidar/points_intensity",
    "image_topic": "/omni_camera/image_raw/image_color",
    "imu_qos": {
      "profile": "sensor_data",
      "depth": 1000
    },
    "points_qos": {
      "profile": "sensor_data"
    },
    "image_qos": {
      "profile": "sensor_data"
    }
  }
}

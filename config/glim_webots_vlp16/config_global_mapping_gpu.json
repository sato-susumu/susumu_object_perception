{
  "global_mapping": {
    "so_name": "libglobal_mapping.so",
    "enable_imu": true,
    "enable_optimization": true,
    "init_pose_damping_scale": 1e8,
    "create_between_factors": true,
    "between_registration_type": "GICP",
    "registration_error_factor_type": "VGICP_GPU",
    "randomsampling_rate": 1.0,
    "submap_voxel_resolution": 0.25,
    "submap_voxel_resolution_max": 0.6,
    "submap_voxel_resolution_dmin": 2.0,
    "submap_voxel_resolution_dmax": 10.0,
    "submap_voxelmap_levels": 2,
    "submap_voxelmap_scaling_factor": 2.0,
    "max_implicit_loop_distance": 6.0,
    "min_implicit_loop_overlap": 0.05,
    "use_isam2_dogleg": false,
    "isam2_relinearize_skip": 1,
    "isam2_relinearize_thresh": 0.05
  }
}
